  "info": {
    "_postman_id": "8baaac4b-ba00-4d9b-872e-ca1da836c1a3",
    "name": "Trulioo Identity Document Verification API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Capture, classify, and verify government-issued identity documents (driver's license, passport, national ID) paired with optional liveness selfie checks. Used to authenticate documents, extract MRZ/barcode data, and match the document photo to a captured selfie. Returns extracted fields, classification confidence, fraud signals, and document images.\n\n\nContact Support:\n Name: Trulioo Support\n Email: support@trulioo.com",
      "type": "text/plain"
    }
  }
