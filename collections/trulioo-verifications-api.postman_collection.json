  "info": {
    "_postman_id": "1c3e639f-c130-41a5-9db4-b79db070a223",
    "name": "Trulioo Verifications API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Trulioo's Normalized API for identity verification (KYC) and electronic identity verification (eIDV). Submit a Verify request with normalized PersonInfo, Communication, Location, NationalIds, and Documents fields and Trulioo's GlobalGateway routes the request across local data sources in 195+ countries. Returns a normalized VerifyResult with Record status, DatasourceResults, RecordStatus, and Errors. Companion endpoints retrieve transaction records, statuses, partial results, and downloadable document images.\n\n\nContact Support:\n Name: Trulioo Support\n Email: support@trulioo.com",
      "type": "text/plain"
    }
  }
