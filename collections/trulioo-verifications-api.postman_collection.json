          "id": "4cb8a7e4-4116-489a-b754-c84ef6a50aaa",
          "name": "Verify A Person",
          "request": {
            "name": "Verify A Person",
            "description": {
              "content": "Submit a Verify request to perform a KYC verification on a person. Trulioo selects the appropriate local datasources for the country specified in the `CountryCode` field, matches the supplied identity fields, and returns a normalized VerifyResult.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v3",
                "verifications",
                "verify"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"AcceptTruliooTermsAndConditions\": \"<boolean>\",\n  \"ConfigurationName\": \"<string>\",\n  \"CountryCode\": \"<string>\",\n  \"DataFields\": {\n    \"PersonInfo\": {\n      \"FirstGivenName\": \"<string>\",\n      \"MiddleName\": \"<string>\",\n      \"FirstSurName\": \"<string>\",\n      \"SecondSurname\": \"<string>\",\n      \"DayOfBirth\": \"<integer>\",\n      \"MonthOfBirth\": \"<integer>\",\n      \"YearOfBirth\": \"<integer>\",\n      \"Gender\": \"<string>\"\n    },\n    \"Location\": {\n      \"BuildingNumber\": \"<string>\",\n      \"BuildingName\": \"<string>\",\n      \"UnitNumber\": \"<string>\",\n      \"StreetName\": \"<string>\",\n      \"StreetType\": \"<string>\",\n      \"City\": \"<string>\",\n      \"StateProvinceCode\": \"<string>\",\n      \"PostalCode\": \"<string>\",\n      \"Country\": \"<string>\"\n    },\n    \"Communication\": {\n      \"Telephone\": \"<string>\",\n      \"MobileNumber\": \"<string>\",\n      \"EmailAddress\": \"<string>\"\n    },\n    \"NationalIds\": [\n      {\n        \"Number\": \"<string>\",\n        \"Type\": \"<string>\",\n        \"CountryCode\": \"<string>\"\n      },\n      {\n        \"Number\": \"<string>\",\n        \"Type\": \"<string>\",\n        \"CountryCode\": \"<string>\"\n      }\n    ],\n    \"Document\": {\n      \"DocumentFrontImage\": \"<byte>\",\n      \"DocumentBackImage\": \"<byte>\",\n      \"LivePhoto\": \"<byte>\",\n      \"DocumentType\": \"<string>\"\n    }\n  },\n  \"CleansedAddress\": \"<boolean>\",\n  \"CustomerReferenceID\": \"<string>\",\n  \"ConsentForDataSources\": [\n    \"<string>\",\n    \"<string>\"\n  ],\n  \"CallBackUrl\": \"<uri>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
