{
  "@context": {
    "@vocab": "https://schema.org/",
    "trulioo": "https://api-evangelist.github.io/trulioo/vocab#",
    "id": "@id",
    "type": "@type",
    "Person": "schema:Person",
    "Organization": "schema:Organization",
    "PostalAddress": "schema:PostalAddress",
    "ContactPoint": "schema:ContactPoint",

    "VerifyRequest": "trulioo:VerifyRequest",
    "VerifyResult": "trulioo:VerifyResult",
    "TransactionRecord": "trulioo:TransactionRecord",
    "DatasourceResult": "trulioo:DatasourceResult",
    "DatasourceField": "trulioo:DatasourceField",
    "AppendedField": "trulioo:AppendedField",
    "BusinessRecord": "trulioo:BusinessRecord",
    "BusinessSearchRequest": "trulioo:BusinessSearchRequest",
    "BusinessVerifyRequest": "trulioo:BusinessVerifyRequest",
    "RiskVerifyResult": "trulioo:RiskVerifyResult",
    "DocumentVerifyResult": "trulioo:DocumentVerifyResult",
    "KnownFacesList": "trulioo:KnownFacesList",

    "TransactionID": { "@id": "trulioo:transactionId", "@type": "xsd:string" },
    "TransactionRecordID": { "@id": "trulioo:transactionRecordId", "@type": "xsd:string" },
    "CountryCode": { "@id": "trulioo:countryCode", "@type": "xsd:string" },
    "ConfigurationName": { "@id": "trulioo:configurationName", "@type": "xsd:string" },
    "RecordStatus": { "@id": "trulioo:recordStatus", "@type": "xsd:string" },
    "DatasourceName": { "@id": "trulioo:datasourceName", "@type": "xsd:string" },
    "FieldName": { "@id": "trulioo:fieldName", "@type": "xsd:string" },
    "ConfidenceScore": { "@id": "trulioo:confidenceScore", "@type": "xsd:decimal" },
    "RiskScore": { "@id": "trulioo:riskScore", "@type": "xsd:decimal" },
    "RiskVerdict": { "@id": "trulioo:riskVerdict", "@type": "xsd:string" },
    "FaceMatchScore": { "@id": "trulioo:faceMatchScore", "@type": "xsd:decimal" },
    "LivenessScore": { "@id": "trulioo:livenessScore", "@type": "xsd:decimal" },
    "JurisdictionOfIncorporation": { "@id": "trulioo:jurisdictionOfIncorporation", "@type": "xsd:string" },
    "BusinessRegistrationNumber": { "@id": "trulioo:businessRegistrationNumber", "@type": "xsd:string" },

    "FirstGivenName": "schema:givenName",
    "FirstSurName": "schema:familyName",
    "DayOfBirth": { "@id": "trulioo:dayOfBirth", "@type": "xsd:integer" },
    "MonthOfBirth": { "@id": "trulioo:monthOfBirth", "@type": "xsd:integer" },
    "YearOfBirth": { "@id": "trulioo:yearOfBirth", "@type": "xsd:integer" },
    "EmailAddress": "schema:email",
    "Telephone": "schema:telephone",
    "BuildingNumber": "schema:streetAddress",
    "StreetName": "schema:streetAddress",
    "City": "schema:addressLocality",
    "StateProvinceCode": "schema:addressRegion",
    "PostalCode": "schema:postalCode",
    "Country": "schema:addressCountry"
  }
}
