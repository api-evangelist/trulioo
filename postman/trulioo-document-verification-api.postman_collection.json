  "info": {
    "_postman_id": "35dafb79-223a-4f47-a001-b536d750ff62",
    "name": "Trulioo Identity Document Verification API",
    "description": "Capture, classify, and verify government-issued identity documents (driver's license, passport, national ID) paired with optional liveness selfie checks. Used to authenticate documents, extract MRZ/barcode data, and match the document photo to a captured selfie. Returns extracted fields, classification confidence, fraud signals, and document images.\n\n\nContact Support:\n Name: Trulioo Support\n Email: support@trulioo.com",
